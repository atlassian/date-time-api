{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "module": "esnext",
    "noEmit": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "esnext",
    "moduleResolution": "bundler",
    "types": ["jest", "node"]
  },
  "exclude": ["**/*.test.ts"],
  "include": ["src"]
}
